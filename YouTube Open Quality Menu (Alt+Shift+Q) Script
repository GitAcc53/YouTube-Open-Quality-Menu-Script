// ==UserScript==
// @name         YouTube Open Quality Menu (Alt+Q)
// @version      37.3
// @description  Fixes focus issues and the Alt+T bug in the New Design Embed. Opens the quality menu directly using Alt+Q.
// @author       Gemini
// @match        *://www.youtube.com/*
// @match        *://www.youtube-nocookie.com/*
// @grant        none
// ==/UserScript==

(function () {
    'use strict';

    // 1. PREVENT BLUE BORDER AND TOOLTIP BUG VIA CSS
    const style = document.createElement('style');
    style.innerHTML = `
        *:focus, .ytp-focused, .ytp-settings-button:focus, .ytp-menuitem:focus {
            outline: none !important;
            box-shadow: none !important;
        }
        .ytp-tooltip.ytp-bottom { pointer-events: none !important; }
    `;
    document.head.appendChild(style);

    function resetSettingsTooltip(btn) {
        if (!btn) return;
        btn.blur();
        // Simulate mouse leave to close the tooltip
        btn.dispatchEvent(new MouseEvent('mouseleave', { bubbles: true, cancelable: true, view: window }));
        btn.setAttribute('aria-expanded', 'false');

        // --- CRITICAL MOVE: Give focus back to the video player itself ---
        const player = document.querySelector('.html5-video-player') || document.querySelector('#movie_player');
        if (player) player.focus();
    }

    function openQualityMenu() {
        const settingsBtn = document.querySelector('.ytp-settings-button') ||
                            document.querySelector('[aria-label*="Settings"]') ||
                            document.querySelector('[aria-label*="Ayarlar"]');

        if (!settingsBtn) return;

        // --- TOGGLE (Open/Close) ---
        const menu = document.querySelector('.ytp-settings-menu');
        const isMenuOpen = menu && menu.style.display !== 'none';

        if (isMenuOpen) {
            settingsBtn.click(); // Close the menu
            // After closing, shift focus to the video to avoid needing an extra click
            setTimeout(() => resetSettingsTooltip(settingsBtn), 50);
            return;
        }

        // --- OPENING AND ENTERING QUALITY SETTINGS ---
        settingsBtn.click();

        let attempts = 0;
        const check = setInterval(() => {
            const items = document.querySelectorAll('.ytp-menuitem, [role="menuitem"]');
            let target = null;

            for (const item of items) {
                // Support for both English and Turkish UI
                if (/quality|kalite/i.test(item.textContent)) {
                    target = item;
                    break;
                }
            }

            if (target) {
                clearInterval(check);
                target.click();

                setTimeout(() => {
                    if(target) target.blur();
                    resetSettingsTooltip(settingsBtn);
                    // Manual tooltip cleanup
                    const tooltips = document.querySelectorAll('.ytp-tooltip');
                    tooltips.forEach(t => t.style.display = 'none');
                }, 100);
            }

            if (++attempts > 20) clearInterval(check);
        }, 50);
    }

    window.addEventListener('keydown', (e) => {
        // Alt + Q check
        if (e.altKey && e.key.toLowerCase() === 'q') {
            const active = document.activeElement;
            // Don't trigger if the user is typing in an input field
            if (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.isContentEditable) return;

            e.preventDefault();
            e.stopImmediatePropagation();
            openQualityMenu();
        }
    }, true);
})();
